---
import { getCollection } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';
import ProfilNav from '../../components/profil/ProfilNav.astro';

const halamanStatis = await getCollection('halaman-statis');
const visiMisiEntry = halamanStatis.find((entry) => entry.data.tipe === 'profil-visi-misi');

if (!visiMisiEntry) {
  throw new Error('Konten halaman visi-misi belum tersedia. Buat file dengan tipe "profil-visi-misi" di collection halaman-statis.');
}

const { Content } = await visiMisiEntry.render();

const breadcrumbItems = [
  { label: 'Beranda', href: '/' },
  { label: 'Profil Desa', href: '/profil/sejarah' },
  { label: 'Visi & Misi' },
];
---

<ContentLayout
  title="Visi dan Misi Desa Makmurjaya"
  description="Visi dan misi pemerintahan Desa Makmurjaya untuk mewujudkan desa yang mandiri dan sejahtera."
  breadcrumbItems={breadcrumbItems}
>
  <ProfilNav currentPath="/profil/visi-misi" />

  <article class="prose prose-green max-w-none">
    <h1 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6">
      {visiMisiEntry.data.judul}
    </h1>

    <!-- Konten Markdown visi dan misi -->
    <div class="mt-6">
      <Content />
    </div>
  </article>
</ContentLayout>
