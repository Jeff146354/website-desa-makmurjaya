---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPath } from '../utils/links';
---

<BaseLayout
  title="Halaman Tidak Ditemukan — Desa Makmurjaya"
  description="Halaman yang Anda cari tidak ditemukan. Kembali ke beranda Website Desa Makmurjaya."
>
  <section class="flex flex-col items-center justify-center min-h-[60vh] px-4 py-16 text-center">
    <p class="text-6xl font-bold text-green-700 mb-4">404</p>
    <h1 class="text-2xl md:text-3xl font-semibold text-gray-800 mb-4">
      Halaman Tidak Ditemukan
    </h1>
    <p class="text-gray-600 mb-8 max-w-md">
      Maaf, halaman yang Anda cari tidak tersedia atau telah dipindahkan.
    </p>
    <a
      href={getPath('/')}
      class="inline-flex items-center gap-2 bg-green-700 hover:bg-green-800 text-white font-medium px-6 py-3 rounded-lg transition-colors focus:outline-2 focus:outline-blue-600 focus:outline-offset-2"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M9.707 14.707a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 1.414L7.414 9H15a1 1 0 110 2H7.414l2.293 2.293a1 1 0 010 1.414z" clip-rule="evenodd" />
      </svg>
      Kembali ke Beranda
    </a>
  </section>
</BaseLayout>
