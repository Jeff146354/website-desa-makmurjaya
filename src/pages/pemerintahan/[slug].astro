---
/**
 * pages/pemerintahan/[slug].astro
 * Halaman detail profil perangkat desa.
 * Requirement 3.4: Menampilkan nama, jabatan, foto, bidang tanggung jawab,
 * dan deskripsi tugas pokok dari perangkat desa yang dipilih.
 */

import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import ContentLayout from '../../layouts/ContentLayout.astro';

export async function getStaticPaths() {
  const allPerangkat = await getCollection('perangkat-desa');
  return allPerangkat.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { nama, jabatan, foto, kontak } = entry.data;
const { Content } = await entry.render();

const breadcrumbItems = [
  { label: 'Beranda', href: '/' },
  { label: 'Pemerintahan Desa', href: '/pemerintahan' },
  { label: nama },
];

const pageTitle = `${nama} — ${jabatan} | Desa Makmurjaya`;
const pageDescription = `Profil ${nama}, ${jabatan} Desa Makmurjaya.`;
---

<ContentLayout
  title={pageTitle}
  description={pageDescription}
  breadcrumbItems={breadcrumbItems}
>
  <article class="max-w-3xl mx-auto">
    {/* Header: Foto & Identitas */}
    <header class="flex flex-col items-center text-center mb-8">
      <div class="w-32 h-32 md:w-40 md:h-40 rounded-full overflow-hidden bg-gray-200 mb-4">
        {foto ? (
          <Image
            src={foto}
            alt={`Foto ${nama}`}
            width={160}
            height={160}
            class="w-full h-full object-cover"
          />
        ) : (
          <div class="w-full h-full flex items-center justify-center bg-gray-300" aria-hidden="true">
            <svg
              class="w-16 h-16 md:w-20 md:h-20 text-gray-500"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z" />
            </svg>
          </div>
        )}
      </div>

      <h1 class="text-2xl md:text-3xl font-bold text-gray-900">
        {nama}
      </h1>
      <p class="text-lg text-green-700 font-medium mt-1">
        {jabatan}
      </p>

      {kontak && (
        <p class="text-sm text-gray-600 mt-2">
          <span class="sr-only">Kontak: </span>
          <a
            href={`tel:${kontak}`}
            class="inline-flex items-center gap-1 hover:text-green-700 transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {kontak}
          </a>
        </p>
      )}
    </header>

    {/* Tugas Pokok & Bidang Tanggung Jawab (dari Markdown body) */}
    <section aria-labelledby="tugas-pokok-heading" class="prose prose-green max-w-none">
      <h2 id="tugas-pokok-heading" class="text-xl font-semibold text-gray-900 mb-4">
        Tugas Pokok & Bidang Tanggung Jawab
      </h2>
      <Content />
    </section>

    {/* Link kembali */}
    <nav class="mt-10 pt-6 border-t border-gray-200">
      <a
        href="/pemerintahan"
        class="inline-flex items-center gap-2 text-green-700 hover:text-green-800 font-medium transition-colors"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Kembali ke Struktur Organisasi
      </a>
    </nav>
  </article>
</ContentLayout>
