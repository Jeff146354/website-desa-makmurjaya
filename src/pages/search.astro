---
/**
 * Halaman Pencarian — client-side search menggunakan Pagefind.
 * Membaca query param ?q= dari URL, lazy load pagefind.js,
 * menampilkan hasil dengan judul, excerpt (keyword highlight), dan tautan.
 *
 * Validates: Requirements 11.2, 11.3, 11.4
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPath } from '../utils/links';

const query = Astro.url.searchParams.get('q') || '';
---

<BaseLayout
  title={query ? `Hasil pencarian: ${query}` : 'Pencarian'}
  description="Cari informasi di website Desa Makmurjaya"
>
  <section class="max-w-3xl mx-auto px-4 py-8" data-pagefind-ignore data-base-url={import.meta.env.BASE_URL}>
    <h1 class="text-2xl font-bold text-gray-900 sm:text-3xl mb-6">Pencarian</h1>

    <!-- Search form -->
    <form
      action={getPath('/search')}
      method="GET"
      role="search"
      aria-label="Formulir pencarian"
      class="mb-8"
    >
      <label for="search-page-input" class="sr-only">Kata kunci pencarian</label>
      <div class="flex gap-2">
        <input
          id="search-page-input"
          type="search"
          name="q"
          value={query}
          placeholder="Masukkan kata kunci..."
          autocomplete="off"
          class="flex-1 px-4 py-3 text-sm border border-gray-300 rounded-md bg-gray-50 focus:bg-white focus:border-green-500 focus:outline-2 focus:outline-blue-600 focus:outline-offset-2 transition-colors"
        />
        <button
          type="submit"
          class="px-5 py-3 bg-green-700 text-white text-sm font-medium rounded-md hover:bg-green-800 focus:outline-2 focus:outline-blue-600 focus:outline-offset-2 transition-colors min-h-[44px] min-w-[44px]"
        >
          Cari
        </button>
      </div>
    </form>

    <!-- Search results container -->
    <div id="search-results" aria-live="polite" aria-atomic="true">
      <!-- Loading state (shown while pagefind loads) -->
      <div id="search-loading" class="hidden text-center py-8 text-gray-500">
        <svg class="animate-spin h-6 w-6 mx-auto mb-2 text-green-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        <p>Memuat hasil pencarian...</p>
      </div>

      <!-- No query state -->
      <div id="search-empty-query" class="text-center py-8 text-gray-500">
        <svg class="h-12 w-12 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <p>Masukkan kata kunci untuk mencari informasi di website ini.</p>
      </div>

      <!-- No results state -->
      <div id="search-no-results" class="hidden text-center py-8">
        <svg class="h-12 w-12 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p class="text-gray-700 font-medium mb-2">Tidak ditemukan hasil</p>
        <p class="text-gray-500 text-sm mb-4">Tidak ada konten yang cocok dengan pencarian Anda.</p>
        <div class="text-left max-w-md mx-auto bg-gray-50 rounded-md p-4">
          <p class="text-sm font-medium text-gray-700 mb-2">Saran pencarian:</p>
          <ul class="text-sm text-gray-600 list-disc list-inside space-y-1">
            <li>Pastikan ejaan kata kunci sudah benar</li>
            <li>Coba gunakan kata kunci yang lebih umum</li>
            <li>Gunakan satu atau dua kata kunci saja</li>
            <li>Coba kata kunci lain yang bermakna serupa</li>
          </ul>
        </div>
      </div>

      <!-- Dev mode fallback -->
      <div id="search-dev-fallback" class="hidden text-center py-8 text-gray-500">
        <svg class="h-12 w-12 mx-auto mb-3 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
        </svg>
        <p class="font-medium text-gray-700">Pencarian tersedia setelah build</p>
        <p class="text-sm mt-1">Jalankan <code class="bg-gray-100 px-1.5 py-0.5 rounded text-xs">npm run build</code> untuk menghasilkan indeks pencarian.</p>
      </div>

      <!-- Results list -->
      <div id="search-results-list" class="hidden">
        <p id="search-results-count" class="text-sm text-gray-600 mb-4"></p>
        <ul id="search-results-items" class="space-y-6"></ul>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  async function initSearch() {
    var query = new URLSearchParams(window.location.search).get('q');
    query = query ? query.trim() : '';

    var loadingEl = document.getElementById('search-loading');
    var emptyQueryEl = document.getElementById('search-empty-query');
    var noResultsEl = document.getElementById('search-no-results');
    var devFallbackEl = document.getElementById('search-dev-fallback');
    var resultsListEl = document.getElementById('search-results-list');
    var resultsCountEl = document.getElementById('search-results-count');
    var resultsItemsEl = document.getElementById('search-results-items');

    function hideAll() {
      if (loadingEl) loadingEl.classList.add('hidden');
      if (emptyQueryEl) emptyQueryEl.classList.add('hidden');
      if (noResultsEl) noResultsEl.classList.add('hidden');
      if (devFallbackEl) devFallbackEl.classList.add('hidden');
      if (resultsListEl) resultsListEl.classList.add('hidden');
    }

    function escapeHtml(text) {
      var div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    // No query — show prompt
    if (!query) {
      if (emptyQueryEl) emptyQueryEl.classList.remove('hidden');
      return;
    }

    // Has query — show loading
    hideAll();
    if (loadingEl) loadingEl.classList.remove('hidden');

    try {
      // Lazy load Pagefind using dynamic import (not processed by Vite bundler with is:inline)
      var baseUrl = document.querySelector('[data-base-url]').getAttribute('data-base-url') || '/';
      var pagefind = await import(baseUrl + 'pagefind/pagefind.js');
      await pagefind.init();

      var search = await pagefind.search(query);

      if (loadingEl) loadingEl.classList.add('hidden');

      if (search.results.length === 0) {
        if (noResultsEl) noResultsEl.classList.remove('hidden');
        return;
      }

      // Display results
      var resultsCount = search.results.length;
      if (resultsCountEl) {
        resultsCountEl.textContent = 'Ditemukan ' + resultsCount + ' hasil untuk "' + query + '"';
      }

      if (resultsItemsEl) {
        resultsItemsEl.innerHTML = '';

        // Load and render up to 20 results
        var resultsToShow = search.results.slice(0, 20);
        var loadedResults = await Promise.all(
          resultsToShow.map(function(r) { return r.data(); })
        );

        for (var i = 0; i < loadedResults.length; i++) {
          var result = loadedResults[i];
          var li = document.createElement('li');
          li.className = 'border-b border-gray-100 pb-4 last:border-0';

          var title = (result.meta && result.meta.title) ? result.meta.title : 'Tanpa Judul';
          var excerpt = result.excerpt || '';
          var url = result.url || '#';

          li.innerHTML =
            '<a href="' + escapeHtml(url) + '" class="group block rounded-md p-3 -mx-3 hover:bg-green-50 transition-colors focus:outline-2 focus:outline-blue-600 focus:outline-offset-2">' +
              '<h2 class="text-lg font-semibold text-green-700 group-hover:text-green-800 mb-1">' + escapeHtml(title) + '</h2>' +
              '<p class="text-sm text-gray-600 leading-relaxed search-excerpt">' + excerpt + '</p>' +
              '<span class="text-xs text-gray-500 mt-1 block">' + escapeHtml(url) + '</span>' +
            '</a>';

          resultsItemsEl.appendChild(li);
        }
      }

      if (resultsListEl) resultsListEl.classList.remove('hidden');
    } catch (err) {
      // Pagefind not available (dev mode or build not run yet)
      hideAll();
      if (devFallbackEl) devFallbackEl.classList.remove('hidden');
    }
  }

  // Run search on page load
  initSearch();
</script>

<style>
  /* Pagefind excerpt highlights */
  .search-excerpt :global(mark) {
    background-color: #fef08a;
    color: inherit;
    padding: 0.05em 0.15em;
    border-radius: 2px;
  }
</style>
