---
/**
 * Halaman Detail Wisata — menampilkan informasi lengkap destinasi wisata
 * berdasarkan slug. Hanya merender bagian yang memiliki data.
 * Mendukung Pagefind indexing via data-pagefind-body dan data-pagefind-meta.
 *
 * Validates: Requirements 6.2, 6.3, 6.4
 */
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import ContentLayout from '../../layouts/ContentLayout.astro';
import WisataGaleri from '../../components/wisata/WisataGaleri.astro';
import WisataDetail from '../../components/wisata/WisataDetail.astro';
import { getPath } from '../../utils/links';

export async function getStaticPaths() {
  const allWisata = await getCollection('wisata', ({ data }) => data.status === 'published');

  return allWisata.map((wisata) => ({
    params: { slug: wisata.slug },
    props: { entry: wisata },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const {
  nama,
  deskripsi_singkat,
  foto_utama,
  galeri_foto,
  jam_operasional,
  harga_tiket,
  kontak,
  petunjuk_akses,
  lokasi_lat,
  lokasi_lng,
  lokasi_label,
} = entry.data;

const breadcrumbItems = [
  { label: 'Beranda', href: getPath('/') },
  { label: 'Wisata', href: getPath('/wisata') },
  { label: nama },
];
---

<ContentLayout
  title={`${nama} — Wisata Desa Makmurjaya`}
  description={deskripsi_singkat}
  breadcrumbItems={breadcrumbItems}
  type="article"
>
  <article
    data-pagefind-body
    data-pagefind-meta={`title:${nama}`}
  >
    {/* Header */}
    <header class="mb-8">
      <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 leading-tight">
        {nama}
      </h1>
    </header>

    {/* Foto utama */}
    {foto_utama && (
      <figure class="mb-8">
        <Image
          src={foto_utama}
          alt={nama}
          width={960}
          format="webp"
          loading="eager"
          class="w-full rounded-lg object-cover"
        />
      </figure>
    )}

    {/* Galeri Foto */}
    {galeri_foto && galeri_foto.length > 0 && (
      <WisataGaleri galeri_foto={galeri_foto} nama={nama} />
    )}

    {/* Deskripsi lengkap (Markdown body) */}
    <div class="prose prose-lg prose-gray max-w-none mb-8 prose-headings:text-gray-900 prose-a:text-green-700 prose-img:rounded-lg">
      <Content />
    </div>

    {/* Detail informasi wisata */}
    <WisataDetail
      nama={nama}
      jam_operasional={jam_operasional}
      harga_tiket={harga_tiket}
      kontak={kontak}
      petunjuk_akses={petunjuk_akses}
      lokasi_lat={lokasi_lat}
      lokasi_lng={lokasi_lng}
      lokasi_label={lokasi_label}
    />
  </article>
</ContentLayout>
