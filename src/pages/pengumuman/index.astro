---
/**
 * Halaman Daftar Pengumuman — menampilkan pengumuman & agenda yang dipublikasikan,
 * diurutkan berdasarkan tanggal terbaru dengan paginasi 10 per halaman.
 *
 * Validates: Requirements 5.1, 5.2, 5.5, 5.6, 5.7
 */
import { getCollection } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';
import PengumumanCard from '../../components/pengumuman/PengumumanCard.astro';
import Pagination from '../../components/ui/Pagination.astro';
import EmptyState from '../../components/ui/EmptyState.astro';
import { paginate } from '../../utils/pagination';

const breadcrumbItems = [
  { label: 'Beranda', href: '/' },
  { label: 'Pengumuman' },
];

// Query pengumuman yang sudah published, sort tanggal desc
const allPengumuman = await getCollection('pengumuman', ({ data }) => data.status === 'published');
const sortedPengumuman = allPengumuman.sort(
  (a, b) => b.data.tanggal.getTime() - a.data.tanggal.getTime()
);

// Paginate halaman 1, 10 item per halaman
const page = 1;
const paginationResult = paginate(sortedPengumuman, page, 10);
---

<ContentLayout
  title="Pengumuman & Agenda — Desa Makmurjaya"
  description="Daftar pengumuman dan agenda kegiatan terbaru dari Desa Makmurjaya."
  breadcrumbItems={breadcrumbItems}
>
  <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-8">Pengumuman & Agenda</h1>

  {paginationResult.data.length === 0 ? (
    <EmptyState message="Belum ada pengumuman yang dipublikasikan." icon="pengumuman" />
  ) : (
    <>
      <div class="grid gap-6 sm:grid-cols-2">
        {paginationResult.data.map((item) => (
          <PengumumanCard
            judul={item.data.judul}
            tanggal={item.data.tanggal}
            kategori={item.data.kategori}
            cuplikan={item.data.cuplikan}
            slug={item.slug}
            tanggal_pelaksanaan={item.data.tanggal_pelaksanaan}
            waktu_pelaksanaan={item.data.waktu_pelaksanaan}
          />
        ))}
      </div>

      <Pagination
        currentPage={paginationResult.currentPage}
        totalPages={paginationResult.totalPages}
        baseUrl="/pengumuman"
      />
    </>
  )}
</ContentLayout>
