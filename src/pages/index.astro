---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/beranda/HeroSection.astro';
import BeritaTerbaru from '../components/beranda/BeritaTerbaru.astro';
import PengumumanTerbaru from '../components/beranda/PengumumanTerbaru.astro';
import HighlightWisata from '../components/beranda/HighlightWisata.astro';
import HighlightUMKM from '../components/beranda/HighlightUMKM.astro';
import { getPath } from '../utils/links';

const seoTitle = 'Beranda — Desa Makmurjaya';
const seoDescription =
  'Website resmi Desa Makmurjaya. Informasi berita desa, pengumuman, wisata, UMKM, dan layanan pemerintahan desa.';

const siteUrl = import.meta.env.SITE ?? 'https://desamakmurjaya.id';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'GovernmentOrganization',
  name: 'Pemerintah Desa Makmurjaya',
  url: siteUrl,
  description: seoDescription,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Makmurjaya',
    addressRegion: 'Jawa Barat',
    addressCountry: 'ID',
  },
};
---

<BaseLayout title={seoTitle} description={seoDescription} jsonLd={jsonLd}>
  <!-- Hero Section -->
  <HeroSection
    foto={getPath('/uploads/hero-desa.png')}
    tagline="Membangun Desa, Memajukan Bersama"
    namaDesaSubtitle="Desa Makmurjaya"
  />

  <!-- Berita Terbaru -->
  <section class="py-12 md:py-16 bg-gradient-to-b from-white to-green-50/50" aria-labelledby="berita-heading">
    <div class="container mx-auto px-4">
      <h2 id="berita-heading" class="text-2xl md:text-3xl font-bold text-gray-900 mb-8 flex items-center gap-3">
        <span class="inline-block w-1.5 h-8 bg-green-600 rounded-full"></span>
        Berita Terbaru
      </h2>
      <BeritaTerbaru />
    </div>
  </section>

  <!-- Pengumuman Terbaru -->
  <section class="py-12 md:py-16 bg-gradient-to-br from-green-50 to-blue-50" aria-labelledby="pengumuman-heading">
    <div class="container mx-auto px-4">
      <h2 id="pengumuman-heading" class="text-2xl md:text-3xl font-bold text-gray-900 mb-8 flex items-center gap-3">
        <span class="inline-block w-1.5 h-8 bg-blue-600 rounded-full"></span>
        Pengumuman &amp; Agenda
      </h2>
      <PengumumanTerbaru />
    </div>
  </section>

  <!-- Highlight Wisata -->
  <section class="py-12 md:py-16 bg-gradient-to-b from-blue-50/50 to-white" aria-labelledby="wisata-heading">
    <div class="container mx-auto px-4">
      <h2 id="wisata-heading" class="text-2xl md:text-3xl font-bold text-gray-900 mb-8 flex items-center gap-3">
        <span class="inline-block w-1.5 h-8 bg-sky-500 rounded-full"></span>
        Wisata Desa
      </h2>
      <HighlightWisata />
    </div>
  </section>

  <!-- Highlight UMKM -->
  <section class="py-12 md:py-16 bg-gradient-to-br from-emerald-50 to-teal-50" aria-labelledby="umkm-heading">
    <div class="container mx-auto px-4">
      <h2 id="umkm-heading" class="text-2xl md:text-3xl font-bold text-gray-900 mb-8 flex items-center gap-3">
        <span class="inline-block w-1.5 h-8 bg-emerald-600 rounded-full"></span>
        UMKM Desa
      </h2>
      <HighlightUMKM />
    </div>
  </section>
</BaseLayout>
