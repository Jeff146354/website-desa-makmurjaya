---
interface Props {
  lat: number;
  lng: number;
  label: string;
  zoom?: number;
}

const { lat, lng, label, zoom = 15 } = Astro.props;
const mapId = `peta-${Math.random().toString(36).substr(2, 9)}`;
const osmUrl = `https://www.openstreetmap.org/?mlat=${lat}&mlon=${lng}#map=${zoom}/${lat}/${lng}`;
---

<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin=""
/>

<div
  id={mapId}
  class="w-full h-[400px] rounded-lg border border-gray-200 shadow-sm z-0"
  role="application"
  aria-label={`Peta lokasi ${label}`}
  data-lat={lat}
  data-lng={lng}
  data-label={label}
  data-zoom={zoom}
>
  <noscript>
    <div class="flex items-center justify-center h-full bg-gray-100 p-4 text-center">
      <p class="text-gray-700">
        Peta tidak dapat ditampilkan karena JavaScript dinonaktifkan.
        <a
          href={osmUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-green-700 underline hover:text-green-900"
        >
          Buka lokasi di OpenStreetMap &rarr;
        </a>
      </p>
    </div>
  </noscript>
</div>

<script>
  async function initMap(container: HTMLElement) {
    const lat = parseFloat(container.dataset.lat || '0');
    const lng = parseFloat(container.dataset.lng || '0');
    const label = container.dataset.label || 'Lokasi';
    const zoom = parseInt(container.dataset.zoom || '15', 10);
    const osmUrl = `https://www.openstreetmap.org/?mlat=${lat}&mlon=${lng}#map=${zoom}/${lat}/${lng}`;

    try {
      const L = await import('leaflet');

      // Fix Leaflet default icon path for bundlers (Vite/Astro)
      const iconDefault = L.icon({
        iconUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon.png',
        iconRetinaUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon-2x.png',
        shadowUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png',
        iconSize: [25, 41],
        iconAnchor: [12, 41],
        popupAnchor: [1, -34],
        shadowSize: [41, 41],
      });

      const map = L.map(container).setView([lat, lng], zoom);

      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution:
          '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
        maxZoom: 19,
      }).addTo(map);

      L.marker([lat, lng], { icon: iconDefault })
        .addTo(map)
        .bindPopup(label)
        .openPopup();
    } catch (err) {
      // Fallback if Leaflet fails to load
      container.innerHTML = `
        <div class="flex items-center justify-center h-full bg-gray-100 p-4 text-center rounded-lg">
          <p class="text-gray-700">
            Peta tidak dapat ditampilkan.
            <a href="${osmUrl}" target="_blank" rel="noopener noreferrer"
               class="text-green-700 underline hover:text-green-900">
              Lihat lokasi di OpenStreetMap &rarr;
            </a>
          </p>
        </div>
      `;
    }
  }

  // Initialize all map containers on the page
  document.addEventListener('DOMContentLoaded', () => {
    const containers = document.querySelectorAll<HTMLElement>('[id^="peta-"]');
    containers.forEach((container) => {
      if (container.dataset.lat) {
        initMap(container);
      }
    });
  });
</script>
