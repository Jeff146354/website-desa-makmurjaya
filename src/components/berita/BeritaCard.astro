---
/**
 * BeritaCard.astro
 * Menampilkan kartu berita individual dengan judul, tanggal (format Indonesia),
 * foto thumbnail (WebP 400px lazy), dan cuplikan 2 baris.
 * Touch target minimal 44x44px untuk aksesibilitas mobile.
 *
 * Validates: Requirements 4.1, 4.2
 */
import { Image } from 'astro:assets';
import { formatTanggalIndonesia } from '../../utils/date';

interface Props {
  judul: string;
  tanggal: Date;
  foto_thumbnail?: ImageMetadata;
  cuplikan?: string;
  slug: string;
}

const { judul, tanggal, foto_thumbnail, cuplikan, slug } = Astro.props;
---

<article class="rounded-lg border border-gray-200 bg-white shadow-sm transition hover:shadow-md overflow-hidden">
  <a
    href={`/berita/${slug}`}
    class="block min-h-[44px] group focus:outline-none focus:ring-2 focus:ring-green-600 focus:ring-offset-2 rounded-lg"
    aria-label={`Baca berita: ${judul}`}
  >
    {/* Foto thumbnail */}
    {foto_thumbnail && (
      <div class="aspect-video w-full overflow-hidden bg-gray-100">
        <Image
          src={foto_thumbnail}
          alt={judul}
          width={400}
          format="webp"
          loading="lazy"
          class="h-full w-full object-cover transition-transform duration-200 group-hover:scale-105"
        />
      </div>
    )}

    {/* Konten */}
    <div class="p-4 sm:p-5">
      <h3 class="text-base sm:text-lg font-semibold text-gray-900 group-hover:text-green-700 transition-colors line-clamp-2">
        {judul}
      </h3>

      <time
        datetime={tanggal.toISOString()}
        class="mt-2 block text-sm text-gray-500"
      >
        {formatTanggalIndonesia(tanggal)}
      </time>

      {cuplikan && (
        <p class="mt-3 text-sm text-gray-600 line-clamp-2">
          {cuplikan}
        </p>
      )}
    </div>
  </a>
</article>
