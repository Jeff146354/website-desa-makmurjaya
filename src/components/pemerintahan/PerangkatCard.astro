---
/**
 * PerangkatCard.astro
 * Menampilkan kartu individual perangkat desa dengan nama, jabatan, dan foto.
 * Kartu merupakan tautan ke halaman detail perangkat.
 * Touch target minimal 44x44px untuk aksesibilitas mobile.
 */

interface Props {
  nama: string;
  jabatan: string;
  slug: string;
  foto?: ImageMetadata;
}

import { Image } from 'astro:assets';
import { getPath } from '../../utils/links';

const { nama, jabatan, slug, foto } = Astro.props;
---

<a
  href={getPath(`/pemerintahan/${slug}`)}
  class="group flex flex-col items-center text-center p-4 rounded-lg
         min-w-[44px] min-h-[44px]
         hover:bg-green-50 focus:outline-none focus:ring-2 focus:ring-green-600 focus:ring-offset-2
         transition-colors duration-200"
  aria-label={`Lihat detail ${nama}, ${jabatan}`}
>
  {/* Foto atau placeholder */}
  <div class="w-20 h-20 md:w-24 md:h-24 rounded-full overflow-hidden bg-gray-200 flex-shrink-0 mb-3">
    {foto ? (
      <Image
        src={foto}
        alt={`Foto ${nama}`}
        width={96}
        height={96}
        class="w-full h-full object-cover"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center bg-gray-300" aria-hidden="true">
        <svg
          class="w-10 h-10 md:w-12 md:h-12 text-gray-500"
          fill="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z" />
        </svg>
      </div>
    )}
  </div>

  {/* Nama & Jabatan */}
  <span class="font-semibold text-sm md:text-base text-gray-900 group-hover:text-green-700 transition-colors">
    {nama}
  </span>
  <span class="text-xs md:text-sm text-gray-600 mt-0.5">
    {jabatan}
  </span>
</a>
