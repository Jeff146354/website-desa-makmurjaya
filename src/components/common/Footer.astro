---
/**
 * Footer component — ditampilkan di setiap halaman.
 * Menampilkan kontak ringkas (alamat, telepon, jam layanan),
 * tautan ke semua halaman utama, dan kredit pengembang.
 *
 * Requirements: 1.7, 12.4
 */
import { getPath } from '../../utils/links';

const currentYear = new Date().getFullYear();

const tautanHalaman = [
  { label: 'Beranda', href: getPath('/') },
  { label: 'Profil Desa', href: getPath('/profil/sejarah') },
  { label: 'Pemerintahan', href: getPath('/pemerintahan') },
  { label: 'Berita', href: getPath('/berita') },
  { label: 'Pengumuman', href: getPath('/pengumuman') },
  { label: 'Wisata', href: getPath('/wisata') },
  { label: 'UMKM', href: getPath('/umkm') },
  { label: 'Galeri', href: getPath('/galeri') },
  { label: 'Kontak', href: getPath('/kontak') },
  { label: 'FAQ', href: getPath('/faq') },
];
---

<footer class="bg-gradient-to-b from-gray-900 to-gray-950 text-gray-300 py-10 mt-16 border-t-4 border-green-600" data-pagefind-ignore>
  <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-3 gap-8">
    <!-- Kontak Ringkas -->
    <div>
      <h3 class="text-green-400 font-semibold text-lg mb-3">Kontak Desa</h3>
      <address class="not-italic space-y-2 text-sm">
        <p class="flex items-start gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span>Jl. Raya Desa No. 1, Desa Makmurjaya</span>
        </p>
        <p class="flex items-start gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <span>(021) 000-0000</span>
        </p>
        <p class="flex items-start gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>Senin – Jumat, 08.00 – 15.00 WIB</span>
        </p>
      </address>
    </div>

    <!-- Tautan Halaman Utama -->
    <div>
      <h3 class="text-green-400 font-semibold text-lg mb-3">Tautan</h3>
      <nav aria-label="Tautan footer">
        <ul class="grid grid-cols-2 gap-x-4 gap-y-1 text-sm">
          {tautanHalaman.map((item) => (
            <li>
              <a
                href={item.href}
                class="hover:text-white transition-colors min-h-[44px] inline-flex items-center focus:outline-2 focus:outline-blue-600 focus:outline-offset-2 rounded"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <!-- Kredit Pengembang -->
    <div>
      <h3 class="text-green-400 font-semibold text-lg mb-3">Pengembang</h3>
      <p class="text-sm">
        Dibangun dengan oleh <strong class="text-white">Tim KKN</strong>
      </p>
      <p class="text-sm mt-2">
        &copy; {currentYear} Desa Makmurjaya. Seluruh hak cipta dilindungi.
      </p>
    </div>
  </div>

  <!-- Garis bawah -->
  <div class="max-w-7xl mx-auto px-4 mt-8 pt-6 border-t border-gray-700">
    <p class="text-xs text-gray-400 text-center">
      Website Profil Desa Makmurjaya — Dibangun dengan Astro &amp; Decap CMS
    </p>
  </div>
</footer>
