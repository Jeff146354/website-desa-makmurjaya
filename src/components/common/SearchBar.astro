---
/**
 * SearchBar component — compact text input with search submit.
 * On submit, redirects to /search?q={keyword}.
 * Designed to fit in the header navigation.
 *
 * Validates: Requirement 11.1
 */
---

<form
  action="/search"
  method="GET"
  class="flex items-center"
  role="search"
  aria-label="Pencarian website"
>
  <label for="search-input" class="sr-only">Cari</label>
  <div class="relative">
    <input
      id="search-input"
      type="search"
      name="q"
      placeholder="Cari..."
      autocomplete="off"
      class="w-32 md:w-44 h-11 pl-3 pr-11 text-sm rounded-full border border-gray-300 bg-gray-50 text-gray-900 placeholder-gray-500 focus:outline-2 focus:outline-blue-600 focus:outline-offset-0 focus:border-blue-600 focus:bg-white transition-colors"
    />
    <button
      type="submit"
      class="absolute right-0 top-1/2 -translate-y-1/2 flex items-center justify-center h-11 w-11 rounded-full text-gray-500 hover:text-blue-600 focus:outline-2 focus:outline-blue-600 focus:outline-offset-2"
      aria-label="Cari"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-4 w-4"
        viewBox="0 0 20 20"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          fill-rule="evenodd"
          d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z"
          clip-rule="evenodd"
        />
      </svg>
    </button>
  </div>
</form>
