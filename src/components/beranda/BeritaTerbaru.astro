---
/**
 * BeritaTerbaru — menampilkan 3 berita terbaru (published) di halaman beranda.
 * Sort by tanggal descending, cuplikan maks 100 karakter.
 * Fallback EmptyState jika tidak ada berita.
 *
 * Validates: Requirements 1.2, 1.8
 */
import { getCollection } from 'astro:content';
import { formatTanggalIndonesia } from '../../utils/date';
import EmptyState from '../ui/EmptyState.astro';

const allBerita = await getCollection('berita', ({ data }) => data.status === 'published');
const beritaTerbaru = allBerita
  .sort((a, b) => b.data.tanggal.getTime() - a.data.tanggal.getTime())
  .slice(0, 3);
---

{beritaTerbaru.length === 0 ? (
  <EmptyState message="Belum ada berita yang tersedia." icon="berita" />
) : (
  <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    {beritaTerbaru.map((berita) => {
      const cuplikan = berita.data.cuplikan
        ? berita.data.cuplikan.length > 100
          ? berita.data.cuplikan.slice(0, 100) + '…'
          : berita.data.cuplikan
        : '';

      return (
        <article class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm transition hover:shadow-md">
          <a href={`/berita/${berita.slug}`} class="block group">
            <h3 class="text-lg font-semibold text-gray-900 group-hover:text-green-700 transition-colors line-clamp-2">
              {berita.data.judul}
            </h3>
            <time
              datetime={berita.data.tanggal.toISOString()}
              class="mt-2 block text-sm text-gray-500"
            >
              {formatTanggalIndonesia(berita.data.tanggal)}
            </time>
            {cuplikan && (
              <p class="mt-3 text-sm text-gray-600 line-clamp-3">{cuplikan}</p>
            )}
          </a>
        </article>
      );
    })}
  </div>
)}
