---
/**
 * GaleriGrid component — menampilkan galeri foto dalam layout CSS Grid responsif,
 * dikelompokkan berdasarkan album. Setiap foto menampilkan caption di bawahnya.
 * Gambar menggunakan Astro <Image> dengan format WebP dan lazy loading.
 *
 * Validates: Requirements 8.1, 8.3, 8.4, 14.2, 14.3
 */
import { Image } from 'astro:assets';

interface GaleriItem {
  id: string;
  judul_foto: string;
  file_foto: ImageMetadata;
  caption?: string;
  album: string;
  urutan: number;
}

interface Props {
  items: GaleriItem[];
}

const { items } = Astro.props;

// Group items by album
const albumGroups: Record<string, GaleriItem[]> = {};
for (const item of items) {
  const album = item.album || 'Umum';
  if (!albumGroups[album]) {
    albumGroups[album] = [];
  }
  albumGroups[album].push(item);
}

// Sort albums alphabetically, but "Umum" goes last
const sortedAlbumNames = Object.keys(albumGroups).sort((a, b) => {
  if (a === 'Umum') return 1;
  if (b === 'Umum') return -1;
  return a.localeCompare(b, 'id');
});
---

<div class="space-y-12">
  {sortedAlbumNames.map((albumName) => {
    const albumItems = albumGroups[albumName];
    return (
      <section aria-labelledby={`album-${albumName.toLowerCase().replace(/\s+/g, '-')}`}>
        <h2
          id={`album-${albumName.toLowerCase().replace(/\s+/g, '-')}`}
          class="text-xl font-semibold text-gray-900 mb-4 border-b border-gray-200 pb-2"
        >
          {albumName}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
          {albumItems.map((item) => (
            <figure class="group relative overflow-hidden rounded-lg bg-gray-100">
              <button
                type="button"
                class="galeri-item w-full cursor-pointer focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 rounded-lg"
                data-album={albumName}
                data-src={item.file_foto.src}
                data-caption={item.caption || item.judul_foto}
                data-id={item.id}
                aria-label={`Lihat foto: ${item.judul_foto}`}
              >
                <Image
                  src={item.file_foto}
                  alt={item.caption || item.judul_foto}
                  width={400}
                  height={400}
                  format="webp"
                  loading="lazy"
                  decoding="async"
                  class="aspect-square w-full object-cover transition-transform duration-300 group-hover:scale-105"
                />
              </button>
              <figcaption class="px-3 py-2 text-sm text-gray-700 bg-white">
                {item.caption || item.judul_foto}
              </figcaption>
            </figure>
          ))}
        </div>
      </section>
    );
  })}
</div>
