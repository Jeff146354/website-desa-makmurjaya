---
/**
 * WisataDetail.astro
 * Menampilkan informasi detail wisata secara kondisional.
 * Bagian yang tidak memiliki data tidak akan dirender.
 *
 * Validates: Requirements 6.2, 6.3, 6.4
 */
import PetaKantor from '../kontak/PetaKantor.astro';

interface Props {
  nama: string;
  jam_operasional?: string;
  harga_tiket?: string;
  kontak?: string;
  petunjuk_akses?: string;
  lokasi_lat?: number;
  lokasi_lng?: number;
  lokasi_label?: string;
}

const {
  nama,
  jam_operasional,
  harga_tiket,
  kontak,
  petunjuk_akses,
  lokasi_lat,
  lokasi_lng,
  lokasi_label,
} = Astro.props;

const hasInfoCards = jam_operasional || harga_tiket || kontak || petunjuk_akses;
const hasPeta = lokasi_lat !== undefined && lokasi_lng !== undefined;
---

{hasInfoCards && (
  <section class="mb-8">
    <h2 class="text-xl font-semibold text-gray-900 mb-4">Informasi Wisata</h2>
    <div class="grid gap-4 sm:grid-cols-2">
      {/* Jam Operasional */}
      {jam_operasional && (
        <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm">
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 text-green-600" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h3 class="text-sm font-medium text-gray-500">Jam Operasional</h3>
              <p class="mt-1 text-base text-gray-900">{jam_operasional}</p>
            </div>
          </div>
        </div>
      )}

      {/* Harga Tiket */}
      {harga_tiket && (
        <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm">
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 text-green-600" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
              </svg>
            </div>
            <div>
              <h3 class="text-sm font-medium text-gray-500">Harga Tiket</h3>
              <p class="mt-1 text-base text-gray-900">{harga_tiket}</p>
            </div>
          </div>
        </div>
      )}

      {/* Kontak / Narahubung — Requirement 6.3 */}
      {kontak && (
        <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm">
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 text-green-600" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <h3 class="text-sm font-medium text-gray-500">Kontak Narahubung</h3>
              <p class="mt-1 text-base text-gray-900">{kontak}</p>
            </div>
          </div>
        </div>
      )}

      {/* Petunjuk Akses — Requirement 6.4 */}
      {petunjuk_akses && (
        <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:col-span-2">
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 text-green-600" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
              </svg>
            </div>
            <div>
              <h3 class="text-sm font-medium text-gray-500">Petunjuk Akses</h3>
              <p class="mt-1 text-base text-gray-900">{petunjuk_akses}</p>
            </div>
          </div>
        </div>
      )}
    </div>
  </section>
)}

{/* Lokasi Peta — menggunakan PetaKantor jika lat/lng tersedia */}
{hasPeta && (
  <section class="mb-8">
    <h2 class="text-xl font-semibold text-gray-900 mb-4">Lokasi</h2>
    <PetaKantor
      lat={lokasi_lat!}
      lng={lokasi_lng!}
      label={lokasi_label || nama}
    />
  </section>
)}
