---
/**
 * WisataCard.astro
 * Menampilkan kartu wisata individual dengan foto utama (WebP lazy),
 * nama destinasi, dan deskripsi singkat.
 * Touch target minimal 44x44px untuk aksesibilitas mobile.
 *
 * Validates: Requirements 6.1
 */
import { Image } from 'astro:assets';

interface Props {
  nama: string;
  slug: string;
  deskripsi_singkat: string;
  foto_utama?: ImageMetadata;
}

const { nama, slug, deskripsi_singkat, foto_utama } = Astro.props;
---

<article class="rounded-lg border border-gray-200 bg-white shadow-sm transition hover:shadow-md overflow-hidden">
  <a
    href={`/wisata/${slug}`}
    class="block min-h-[44px] group focus:outline-none focus:ring-2 focus:ring-green-600 focus:ring-offset-2 rounded-lg"
    aria-label={`Lihat wisata: ${nama}`}
  >
    {/* Foto utama */}
    <div class="aspect-[4/3] w-full overflow-hidden bg-gray-100">
      {foto_utama ? (
        <Image
          src={foto_utama}
          alt={nama}
          width={400}
          format="webp"
          loading="lazy"
          class="h-full w-full object-cover transition-transform duration-200 group-hover:scale-105"
        />
      ) : (
        <div class="flex h-full w-full items-center justify-center text-gray-400" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
      )}
    </div>

    {/* Konten */}
    <div class="p-4 sm:p-5">
      <h3 class="text-base sm:text-lg font-semibold text-gray-900 group-hover:text-green-700 transition-colors line-clamp-2">
        {nama}
      </h3>
      <p class="mt-2 text-sm text-gray-600 line-clamp-2">
        {deskripsi_singkat}
      </p>
    </div>
  </a>
</article>
