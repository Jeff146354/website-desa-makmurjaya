---
import SEOHead from '../components/common/SEOHead.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import BackToTop from '../components/common/BackToTop.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  publishedDate?: string;
  jsonLd?: object;
  canonical?: string;
}

const { title, description, image, type, publishedDate, jsonLd, canonical } = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <SEOHead
      title={title}
      description={description}
      image={image}
      type={type}
      publishedDate={publishedDate}
      jsonLd={jsonLd}
      canonical={canonical}
    />
  </head>
  <body class="min-h-screen flex flex-col bg-white text-gray-900 text-base antialiased">
    <!-- Skip Navigation Link — Requirement 18.2 -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:bg-white focus:px-4 focus:py-2 focus:rounded-md focus:shadow-md focus:text-green-700 focus:font-medium focus:outline-2 focus:outline-blue-600"
    >
      Langsung ke konten
    </a>

    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <BackToTop />
    <Footer />
  </body>
</html>
